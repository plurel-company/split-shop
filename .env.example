# =============================================================================
# Ante Demo Store — environment variables
# Copy to .env.local for local dev. Never commit real secrets.
# Docs: https://splitante.com/docs/getting-started
# =============================================================================

# --- Public (embedded in the browser bundle) ---------------------------------

# Merchant ID from Ante dashboard → Developers (ante_merch_*)
NEXT_PUBLIC_ANTE_MERCHANT_ID=ante_merch_your_id

# Live publishable key — used when the header switch is set to Live
# On Vercel Production/Preview, this is typically the unqualified name:
NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY=ante_pk_live_your_key

# Optional explicit live key (overrides NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY when set)
# NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY_LIVE=ante_pk_live_your_key

# Test / sandbox publishable key — used when the header switch is set to Test
NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY_TEST=ante_pk_test_your_key

# Absolute origin for product image URLs sent to Ante hosted checkout.
# Must match your deployed domain (defaults to ante-demo-store.vercel.app).
NEXT_PUBLIC_SITE_URL=https://your-store.vercel.app

# --- Server only (never expose to the client) --------------------------------

# Cart HMAC signing secret — Developers → Signing (ante_sign_*)
# Shared across test and live modes for a single merchant account.
ANTE_SIGNING_SECRET=ante_sign_your_signing_secret

# Secret API keys — Developers → Credentials (ante_sk_*)
# Required for session create/cancel (payments:write). Never expose to the client.
ANTE_SECRET_KEY=ante_sk_live_your_secret_key
ANTE_SECRET_KEY_TEST=ante_sk_test_your_secret_key

# Optional explicit live secret key (overrides ANTE_SECRET_KEY when set)
# ANTE_SECRET_KEY_LIVE=ante_sk_live_your_secret_key

# Live webhook signing secret — Webhooks endpoint in dashboard (whsec_*)
ANTE_WEBHOOK_SECRET=whsec_your_live_webhook_secret

# Optional explicit live webhook secret (overrides ANTE_WEBHOOK_SECRET when set)
# ANTE_WEBHOOK_SECRET_LIVE=whsec_your_live_webhook_secret

# Test webhook signing secret — for sandbox group.funded deliveries
ANTE_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret

# --- Observability (optional) ------------------------------------------------

# Sentry DSN — create a Next.js project at https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=https://…@o….ingest.sentry.io/…
# SENTRY_DSN=https://…@o….ingest.sentry.io/…

# Source map upload on Vercel build (optional)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=ante-demo-store
# SENTRY_AUTH_TOKEN=…
