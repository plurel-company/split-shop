# Public — safe for the browser bundle
NEXT_PUBLIC_ANTE_MERCHANT_ID=ante_merch_your_id

# Publishable keys — set one or both; use the header switch in the store to toggle
NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY_TEST=ante_pk_test_your_key
NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY_LIVE=ante_pk_live_your_key
# Legacy single key (treated as test unless it starts with ante_pk_live_)
# NEXT_PUBLIC_ANTE_PUBLISHABLE_KEY=ante_pk_test_your_key

# Absolute URLs for product images sent to Ante (defaults to ante-demo-store.vercel.app)
NEXT_PUBLIC_SITE_URL=https://your-store.vercel.app

# Server only — never commit real values
ANTE_SIGNING_SECRET=ante_sign_your_signing_secret
ANTE_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret
ANTE_WEBHOOK_SECRET_LIVE=whsec_your_live_webhook_secret
# Legacy single webhook secret (used for test if ANTE_WEBHOOK_SECRET_TEST is unset)
# ANTE_WEBHOOK_SECRET=whsec_your_webhook_secret
